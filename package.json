{
  "name": "app-ganadero-ovino",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:single": "tsc -b && vite build --config vite.config.singlefile.ts",
    "preview": "vite preview",
    "lint": "eslint .",
